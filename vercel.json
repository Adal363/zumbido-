{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev -- --host 0.0.0.0",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "vite",
  "outputDirectory": "dist",
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "public": true,
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ]
}
